{
  "name": "claude-drive",
  "version": "0.1.0",
  "description": "Voice-first multi-operator pair programming for Claude Code CLI",
  "author": "Harrison Halperin <harrisonhalperin@gmail.com> (https://github.com/hhalperin)",
  "homepage": "https://github.com/hhalperin/claude-drive",
  "type": "module",
  "main": "out/cli.js",
  "bin": {
    "claude-drive": "./out/cli.js"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "npm run compile",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "start": "node out/cli.js start"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@anthropic-ai/sdk": "latest",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^17.3.1",
    "edge-tts-universal": "^1.4.0",
    "ink": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.0.0",
    "readline": "^1.3.0",
    "say": "^0.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.claude/"
    ],
    "extensionsToTreatAsEsm": [
      ".ts",
      ".tsx"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  }
}
